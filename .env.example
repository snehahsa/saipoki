# SaiPoke web + game (local or Railway)

# Telegram bot (optional locally)
# BOT_TOKEN=
# WEBAPP_URL=https://saipoki-production.up.railway.app

# Flask web app (default 5000)
PORT=5000

# Game server port — must differ from Flask PORT locally
GAME_PORT=3001

# Flask → game server proxy (REST: /getPlayersInRoom, /health)
# Railway web service: public HTTPS URL or private http://${{game.RAILWAY_PRIVATE_DOMAIN}}:${{game.PORT}}
GAME_SERVER_INTERNAL=http://127.0.0.1:3001

# Browser socket.io connects here directly (required for multiplayer on Railway)
# If GAME_SERVER_INTERNAL is public HTTPS, this is inferred automatically.
# GAME_SOCKET_URL=https://game-production-xxxx.up.railway.app

# Game server CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5000

# Postgres on Railway (optional locally)
# DATABASE_URL=

# SQLite path — on Railway mount a volume at /data and set DB_PATH=/data/users.db
# (defaults to /data/users.db when /data is writable, else ./users.db locally)
# DB_PATH=/data/users.db

# $POKEQUEST treasury wallet + mint — edit data/game_wallet.json (no .env vars needed)

# 0 = guest play (no wallet); 1 = require wallet connect + token gating
# WALLET_CHECK=0
# GUEST_STARTING_BALANCE=0

# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=...
