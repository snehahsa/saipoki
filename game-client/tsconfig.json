{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["../gather-clone/frontend/*"],
      "@game/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"]
}
